# Variables Cloud Run — service sac-api (Firebase Hosting)
# Remplacez VOTRE-PROJECT-ID par l'ID Firebase réel.

NODE_ENV=production
COOKIE_SECURE=true
DATABASE_PATH=/tmp/sac.db
UPLOAD_DIR=/tmp/uploads
JWT_ACCESS_SECRET=<secret-32-chars-minimum>
JWT_REFRESH_SECRET=<autre-secret-32-chars-minimum>
SAC_PLATFORM_SECRET=<secret-platforme>
ALLOWED_ORIGINS=https://VOTRE-PROJECT-ID.web.app,https://VOTRE-PROJECT-ID.firebaseapp.com,http://localhost:5000
FRONTEND_URL=https://VOTRE-PROJECT-ID.web.app
EMAIL_FROM=noreply@smartacademy.cd

# Note : /tmp est éphémère sur Cloud Run. Pour la production durable,
# utilisez un volume Cloud Run monté sur /data ou Cloud SQL PostgreSQL.
