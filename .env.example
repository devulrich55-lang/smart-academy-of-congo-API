# --- API Smart Academy (Render / local) ---

JWT_ACCESS_SECRET=changez-moi-32-caracteres-minimum
JWT_REFRESH_SECRET=changez-moi-32-caracteres-minimum
NODE_ENV=production
ALLOWED_ORIGINS=https://smart-academy-of-congo-dbfm.onrender.com,https://smart-academy-of-congoat.onrender.com,https://www.evosmartuni.com,https://evosmartuni.com
FRONTEND_URL=https://smart-academy-of-congo-dbfm.onrender.com
CROSS_ORIGIN_AUTH=true

# --- Gmail (mot de passe oublié) ---
# 1. Activez la validation en 2 étapes sur le compte Google
# 2. Créez un « Mot de passe d'application » : https://myaccount.google.com/apppasswords
# 3. Collez les variables ci-dessous dans Render → Environment (service API)

GMAIL_USER=votre-compte@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optionnel (sinon dérivé de GMAIL_*)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# EMAIL_FROM=votre-compte@gmail.com

