# Développement local — Smart Academy API

# --- MySQL (recommandé, identique à la production) ---
# DATABASE_BACKEND=mysql
# DATABASE_URL=mysql://root:@127.0.0.1:3306/smart_academy
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=smart_academy

# --- SQLite (secours local si MySQL absent) ---
# Ne pas définir DATABASE_URL ni MYSQL_PASSWORD

NODE_ENV=development
JWT_ACCESS_SECRET=dev-only-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=dev-only-refresh-secret-min-32-chars-long!
UPLOAD_DIR=./uploads
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
FRONTEND_URL=http://localhost:5500
