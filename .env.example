# Copier vers .env pour le développement local
NODE_ENV=development
PORT=8000

# Obligatoire en production (32+ caractères aléatoires)
JWT_ACCESS_SECRET=dev-only-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=dev-only-refresh-secret-min-32-chars-long!

# Origines autorisées (CORS) — séparer par des virgules, sans espace superflu
# Exemple prod Firebase :
# ALLOWED_ORIGINS=https://VOTRE-PROJECT-ID.web.app,https://VOTRE-PROJECT-ID.firebaseapp.com
# Exemple prod Vercel :
# ALLOWED_ORIGINS=https://VOTRE-APP.vercel.app
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5500,http://127.0.0.1:5500,http://localhost:5000,http://127.0.0.1:5000

COOKIE_SECURE=false
FRONTEND_URL=http://127.0.0.1:8000
CROSS_ORIGIN_AUTH=false

DATABASE_PATH=./data/sac.db
UPLOAD_DIR=./uploads
SAC_PLATFORM_SECRET=dev-platform-secret-change-in-production

RESET_TOKEN_HOURS=1
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@smartacademy.cd
