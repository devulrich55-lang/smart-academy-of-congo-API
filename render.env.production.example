# Copier ces variables dans Render → smart-academy-of-congo-API-1 → Environment
# MySQL obligatoire en production (plus de SQLite sur Render)

NODE_ENV=production
COOKIE_SECURE=true
CROSS_ORIGIN_AUTH=true
DATABASE_BACKEND=mysql

# Option A — URL complète (recommandé)
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/smart_academy

# Option B — variables séparées
# MYSQL_HOST=your-mysql-host.com
# MYSQL_PORT=3306
# MYSQL_USER=sac_user
# MYSQL_PASSWORD=your-secure-password
# MYSQL_DATABASE=smart_academy

# Fichiers uploadés (disque persistant Render monté sur /data)
UPLOAD_DIR=/data/uploads

ALLOWED_ORIGINS=https://smart-academy-of-congo-dbfm.onrender.com
FRONTEND_URL=https://smart-academy-of-congo-dbfm.onrender.com

API_PAGE_DEFAULT=50
API_PAGE_MAX=200

# JWT_ACCESS_SECRET, JWT_REFRESH_SECRET, SAC_PLATFORM_SECRET : déjà définis sur Render
