# Copier dans Render → smart-academy-of-congo-API-1 → Environment

#

# ═══ MODE TEST (gratuit / petit budget, 30–5000 comptes) ═══

# Voir MODE-TEST-RENDER.md — NE PAS utiliser DATABASE_URL



NODE_ENV=production

COOKIE_SECURE=true

CROSS_ORIGIN_AUTH=true

DATABASE_BACKEND=sqlite

DATABASE_PATH=/data/sac.db

UPLOAD_DIR=/data/uploads



ALLOWED_ORIGINS=https://smart-academy-of-congo-dbfm.onrender.com

FRONTEND_URL=https://smart-academy-of-congo-dbfm.onrender.com



GMAIL_USER=votre-compte@gmail.com

GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

RESET_TOKEN_HOURS=1



API_PAGE_DEFAULT=50

API_PAGE_MAX=200



# Disque Render obligatoire : /data monté (1 Go minimum)

# JWT_ACCESS_SECRET, JWT_REFRESH_SECRET : déjà sur Render



# ═══ MODE PRODUCTION (plus tard, projet financé) ═══

# Remplacer par :

# DATABASE_BACKEND=mysql

# DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/smart_academy

# Supprimer DATABASE_PATH

